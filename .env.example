# ============================================================================
# VERCEL ENVIRONMENT VARIABLES
# ============================================================================
# Add these to Vercel → Settings → Environment Variables
# These are NEVER exposed to the browser (server-side only)

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# AI Services
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-claude-key
OPENROUTER_API_KEY=your-openrouter-key
GROQ_API_KEY=your-groq-key
DEEPSEEK_API_KEY=your-deepseek-key (optional)

# ============================================================================
# LOCAL DEVELOPMENT ONLY (.env.local)
# ============================================================================
# For local development, create a .env.local file with the above variables
# This file is gitignored and never committed to the repository
